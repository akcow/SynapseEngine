# ==========================================
# Mini Memory Engine Environment Variables
# ==========================================

# 1. Database Configuration (Required)
# Use a valid PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/memory_db

# 2. Extractor Mode (Required)
# 'rule' - Uses deterministic mock extractions (Good for testing/development)
# 'llm' - Uses OpenAI LLM for real semantic extraction
EXTRACTOR_MODE=rule

# 3. LLM Configuration (Required if EXTRACTOR_MODE=llm)
OPENAI_API_KEY=your_openai_api_key_here
